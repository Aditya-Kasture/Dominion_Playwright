# ─── Dominion Group — Portal Automation Credentials ────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.
#
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ─── BGE Portal (myaccount.bge.com) ─────────────────────────────────────────
# Abdul: BGE account email for construction@thedominiongroup.com
BGE_EMAIL=construction@thedominiongroup.com

# Abdul: BGE portal password for the account above
BGE_PASSWORD=

# Override the login URL only if BGE changes it (leave blank to use default)
BGE_LOGIN_URL=https://myaccount.bge.com/sign-in

# Script mode: audit | paperless | bills | full  (also settable via npm run bge:*)
BGE_MODE=full


# ─── IMAP (for BGE OTP code retrieval) ───────────────────────────────────────
# Abdul: IMAP settings for construction@thedominiongroup.com.
# If this is a Gmail address, generate a Google App Password at:
#   Google Account → Security → 2-Step Verification → App Passwords
# Use the generated 16-character app password here — NOT the normal login password.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=construction@thedominiongroup.com
IMAP_PASSWORD=


# ─── Baltimore City Water Portal ─────────────────────────────────────────────
# Abdul: Water portal credentials for construction@thedominiongroup.com.
# Confirm the exact login URL — default assumed below.
WATER_EMAIL=construction@thedominiongroup.com
WATER_PASSWORD=

# Abdul: confirm this is the correct water portal login page
WATER_LOGIN_URL=https://cityservices.baltimorecity.gov/water/Login

# Script mode: audit | paperless | bills | full  (also settable via npm run water:*)
WATER_MODE=full


# ─── PostgreSQL — Abdul's DB ─────────────────────────────────────────────────
# Abdul: DB connection details for the Dominion PostgreSQL database.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=


# ─── Playwright runtime ───────────────────────────────────────────────────────
# Set to "false" to show the browser window (useful for audit runs)
HEADLESS=true
